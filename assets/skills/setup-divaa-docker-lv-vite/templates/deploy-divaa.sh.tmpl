#!/usr/bin/env bash
# {{SLUG}} — one-command deploy onto the shared divaa-docker host (topology A).
#
#   ./docker/deploy-divaa.sh dev     # Vite HMR overlay (default)
#   ./docker/deploy-divaa.sh prod    # built assets, base compose file only
#
# Run from the PROJECT ROOT on the Windows PC (Git Bash), not from docker/.
# Idempotent: safe to re-run. Every step is skipped or reconciled if already done.
#
# ⚠️ divaa-docker is SHARED — it runs ~25 containers for 6+ sibling projects.
#    Steps that mutate shared state (the MySQL server, container/router names on
#    the `proxy` network) are gated behind an explicit y/N confirmation and a
#    collision check. Do not add --yes to a first-time deploy.
#
# Secrets: DB/Redis passwords are read from the host's ~/data/.env and injected
# into the host-only .env.divaa. Nothing is printed, nothing is committed.

set -euo pipefail

MODE="${1:-dev}"
ASSUME_YES="${ASSUME_YES:-0}"
HOST="divaa-docker"

SLUG="{{SLUG}}"
PREFIX="{{PREFIX}}"
DB="{{DB}}"
PROJECT_DIR="{{PROJECT_DIR}}"
BETA_PATH="{{BETA_PATH}}"
APP_DOMAIN="{{APP_DOMAIN}}"
VITE_DOMAIN="{{VITE_DOMAIN}}"
MUTAGEN_NAME="{{MUTAGEN_NAME}}"

BASE_F="docker-compose.divaa.yml"
DEV_F="docker-compose.divaa.dev.yml"
if [ "$MODE" = "dev" ]; then
  COMPOSE="docker compose -f $BASE_F -f $DEV_F"
elif [ "$MODE" = "prod" ]; then
  COMPOSE="docker compose -f $BASE_F"
else
  echo "usage: $0 [dev|prod]" >&2; exit 2
fi

say()  { printf '\n\033[1;36m==> %s\033[0m\n' "$*"; }
warn() { printf '\033[1;33m !! %s\033[0m\n' "$*" >&2; }
die()  { printf '\033[1;31mFATAL: %s\033[0m\n' "$*" >&2; exit 1; }

# Gate before any mutation of SHARED host state. Reads from the terminal so it
# still prompts when the script's stdin is a pipe.
confirm() {
  local prompt="$1"
  if [ "$ASSUME_YES" = "1" ]; then warn "ASSUME_YES=1 — auto-confirming: $prompt"; return 0; fi
  local reply=""
  read -r -p "$prompt [y/N] " reply < /dev/tty || die "no terminal to confirm on; re-run interactively"
  case "$reply" in [yY]|[yY][eE][sS]) return 0 ;; *) die "aborted by user" ;; esac
}

[ -f artisan ] || die "run me from the project root (no ./artisan here)"

# ---------------------------------------------------------------- 0. preflight
say "Preflight"
ssh -o BatchMode=yes "$HOST" 'echo ok' >/dev/null 2>&1 || die "cannot ssh $HOST"
command -v mutagen >/dev/null 2>&1 || die "mutagen not installed (scoop install mutagen)"
[ -f .env.divaa ]  || die ".env.divaa missing — run generate.mjs first"
[ -f mutagen.yml ] || die "mutagen.yml missing — run generate.mjs first"
echo "  ssh ok · mutagen ok · config present · mode=$MODE"

# Read-only hosts check. Reading needs no elevation (writing does), so this only
# warns and points at the script that handles elevation properly. A missing -vite
# entry is the classic "app loads but the SPA never mounts" trap, and it is
# invisible from the host side — so catch it here, not after a clean-looking deploy.
hostsfile="/c/Windows/System32/drivers/etc/hosts"
if [ -r "$hostsfile" ]; then
  missing=""
  for d in "$APP_DOMAIN" $([ "$MODE" = dev ] && echo "$VITE_DOMAIN"); do
    esc="$(printf '%s' "$d" | sed 's/\./\\./g')"
    # The hostname must be a WHOLE whitespace-delimited token on an "<ip> <name>..."
    # line. Without the leading "(.*[[:space:]])?" anchor, "2026.app.test" would
    # match inside "innerp-2026.app.test" and wrongly suppress the warning.
    grep -qiE "^[[:space:]]*[0-9.]+[[:space:]]+(.*[[:space:]])?${esc}([[:space:]]|$)" "$hostsfile" \
      || missing="$missing $d"
  done
  if [ -n "$missing" ]; then
    warn "hosts entries MISSING:$missing"
    warn "  this PC won't resolve the app (a missing -vite entry = blank SPA)"
    warn "  fix: powershell -NoProfile -ExecutionPolicy Bypass -File docker/hosts-divaa.ps1 -Elevate"
  else
    echo "  hosts entries present"
  fi
else
  warn "can't read $hostsfile — skipping hosts check"
fi

# Container-name collision on the SHARED docker daemon would clobber a sibling
# project's containers. Check BEFORE we create anything.
say "Checking for name collisions on the shared host"
existing="$(ssh "$HOST" "docker ps -a --format '{{.Names}}' | grep -E '^${PREFIX}-(app|web|vite)\$' || true")"
if [ -n "$existing" ]; then
  echo "  containers already exist for prefix '${PREFIX}':"
  echo "$existing" | sed 's/^/    /'
  echo "  (fine if this is a redeploy of THIS project — abort if '${PREFIX}' belongs to someone else)"
  confirm "  Reuse/replace these containers?"
else
  echo "  none — prefix '${PREFIX}' is free"
fi

# ------------------------------------------------------------- 1. database
# SHARED MySQL. CREATE DATABASE IF NOT EXISTS is idempotent and cannot drop
# data, but it is still a write to infrastructure other projects depend on.
say "Database"
db_exists="$(ssh "$HOST" "PW=\"\$(grep MYSQL_ROOT_PASSWORD ~/data/.env | cut -d= -f2)\"; \
  docker exec -i mysql mysql -uroot -p\"\$PW\" -N -B \
  -e \"SELECT COUNT(*) FROM information_schema.schemata WHERE schema_name='${DB}';\" 2>/dev/null")"
if [ "$db_exists" = "1" ]; then
  echo "  '${DB}' already exists — nothing to do"
else
  echo "  '${DB}' does NOT exist on the shared MySQL server."
  confirm "  CREATE DATABASE ${DB} on the SHARED MySQL?"
  ssh "$HOST" "PW=\"\$(grep MYSQL_ROOT_PASSWORD ~/data/.env | cut -d= -f2)\"; \
    docker exec -i mysql mysql -uroot -p\"\$PW\" \
    -e \"CREATE DATABASE IF NOT EXISTS ${DB} CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;\""
  echo "  created"
fi

# --------------------------------------------------- 2. secrets: scp + inject
# .env.divaa is excluded from Mutagen (host copy is authoritative once injected),
# so it is copied explicitly. Passwords go through the environment into awk's
# ENVIRON[] — no escape processing, so any special char is written byte-for-byte.
say "Secrets (.env.divaa → host, inject passwords)"
ssh "$HOST" "mkdir -p '${BETA_PATH}'"
if ssh "$HOST" "grep -q '^DB_PASSWORD=__INJECT_ON_HOST__\$' '${BETA_PATH}/.env.divaa' 2>/dev/null" \
   || ! ssh "$HOST" "test -f '${BETA_PATH}/.env.divaa'"; then
  scp -q ./.env.divaa "${HOST}:${BETA_PATH}/.env.divaa"
else
  echo "  host .env.divaa already has injected secrets — leaving it alone"
  echo "  (delete it on the host to force a re-copy from the PC template)"
fi
ssh "$HOST" "
  set -e
  export MP=\"\$(grep MYSQL_ROOT_PASSWORD ~/data/.env | cut -d= -f2)\"
  export RP=\"\$(grep REDIS_PASSWORD ~/data/.env | cut -d= -f2)\"
  f='${BETA_PATH}/.env.divaa'
  awk '
    /^DB_PASSWORD=__INJECT_ON_HOST__\$/    {print \"DB_PASSWORD=\" ENVIRON[\"MP\"]; next}
    /^REDIS_PASSWORD=__INJECT_ON_HOST__\$/ {print \"REDIS_PASSWORD=\" ENVIRON[\"RP\"]; next}
    {print}
  ' \"\$f\" > \"\$f.tmp\" && mv \"\$f.tmp\" \"\$f\"
  chmod 600 \"\$f\"
"
ssh "$HOST" "grep -q '__INJECT_ON_HOST__' '${BETA_PATH}/.env.divaa'" \
  && die "placeholders still present in host .env.divaa — is ~/data/.env readable?" || true
echo "  injected + verified (no placeholders remain)"

# ------------------------------------------------------------- 3. file sync
# `mutagen project start` reads ./mutagen.yml — which carries the permissions
# block (0644/0755). Do NOT substitute `mutagen sync create`: a CLI-created
# session defaults to Portable mode and every synced file lands 0600, which
# php-fpm (www-data) cannot read.
say "Mutagen sync"
mutagen daemon start >/dev/null 2>&1 || true
if mutagen sync list "$MUTAGEN_NAME" >/dev/null 2>&1; then
  echo "  session '$MUTAGEN_NAME' already running"
else
  mutagen project start
  echo "  started"
fi
echo "  waiting for the initial scan to settle..."
for _ in $(seq 1 60); do
  if mutagen sync list "$MUTAGEN_NAME" 2>/dev/null | grep -q 'Watching for changes'; then break; fi
  sleep 2
done
mutagen sync list "$MUTAGEN_NAME" | grep -qi 'conflict' && warn "sync reports conflicts — resolve before trusting the deploy" || true
# Prove the permissions block actually took effect on the host side.
mode="$(ssh "$HOST" "stat -c '%a' '${BETA_PATH}/artisan' 2>/dev/null || echo missing")"
case "$mode" in
  644|664|755) echo "  host artisan mode $mode — permissions block OK" ;;
  600) die "host artisan is 0600 — the permissions block did NOT apply. You are on a
       CLI-created session. Run: mutagen sync terminate $MUTAGEN_NAME && mutagen project start" ;;
  missing) die "artisan not on the host yet — sync did not complete" ;;
  *) warn "unexpected mode '$mode' on host artisan" ;;
esac

# ------------------------------------------------------- 4. build + bring up
say "Compose up ($MODE)"
ssh "$HOST" "cd '${BETA_PATH}' && $COMPOSE up -d --build"

# ------------------------------------------------------------ 5. first-run
say "First-run (composer, key, migrate)"
ssh "$HOST" "docker exec ${PREFIX}-app composer install $([ "$MODE" = prod ] && echo '--no-dev --optimize-autoloader')"
ssh "$HOST" "docker exec ${PREFIX}-app chown -R www-data:www-data storage bootstrap/cache"

# APP_KEY / JWT_SECRET come from the synced .env; generate only if absent.
if ! ssh "$HOST" "docker exec ${PREFIX}-app sh -c 'grep -q \"^APP_KEY=base64:\" .env'" 2>/dev/null; then
  echo "  APP_KEY missing — generating"
  ssh "$HOST" "docker exec ${PREFIX}-app php artisan key:generate"
fi
if ssh "$HOST" "docker exec ${PREFIX}-app sh -c 'test -d vendor/php-open-source-saver/jwt-auth'" 2>/dev/null; then
  if ! ssh "$HOST" "docker exec ${PREFIX}-app sh -c 'grep -qE \"^JWT_SECRET=.+\" .env'" 2>/dev/null; then
    echo "  JWT_SECRET missing — generating"
    ssh "$HOST" "docker exec ${PREFIX}-app php artisan jwt:secret"
  fi
fi

if [ "$MODE" = "dev" ]; then
  # A cached PRODUCTION config silently defeats the dev overlay's APP_ENV/APP_DEBUG
  # flip — Laravel reads bootstrap/cache/config.php and ignores the env entirely.
  # Symptom: overlay is up but the app still behaves as production (no debug page).
  ssh "$HOST" "docker exec ${PREFIX}-app php artisan config:clear"
  ssh "$HOST" "docker exec ${PREFIX}-app php artisan migrate --seed"
else
  ssh "$HOST" "docker exec ${PREFIX}-app php artisan migrate --force"
  ssh "$HOST" "docker exec ${PREFIX}-app php artisan config:cache"
fi

# -------------------------------------------------------------- 6. verify
say "Verify"
code="$(ssh "$HOST" "curl -sk --resolve ${APP_DOMAIN}:443:127.0.0.1 -o /dev/null -w '%{http_code}' https://${APP_DOMAIN}/")"
echo "  https://${APP_DOMAIN}/ -> $code"
case "$code" in 2*|3*) ;; *) warn "app did not return 2xx/3xx — check: ssh $HOST 'docker logs ${PREFIX}-app'" ;; esac

if [ "$MODE" = "dev" ]; then
  vcode="$(ssh "$HOST" "curl -sk --resolve ${VITE_DOMAIN}:443:127.0.0.1 -o /dev/null -w '%{http_code}' https://${VITE_DOMAIN}/@vite/client")"
  echo "  https://${VITE_DOMAIN}/@vite/client -> $vcode"
  case "$vcode" in 2*) ;; *) warn "Vite not serving yet — it may still be running npm install: ssh $HOST 'docker logs -f ${PREFIX}-vite'" ;; esac
fi

say "Done — open https://${APP_DOMAIN}"
if [ "$MODE" = "dev" ]; then
cat <<EOF
  Both hosts entries must exist on THIS PC or the SPA loads blank:
    192.168.1.21  ${APP_DOMAIN}
    192.168.1.21  ${VITE_DOMAIN}
EOF
fi
