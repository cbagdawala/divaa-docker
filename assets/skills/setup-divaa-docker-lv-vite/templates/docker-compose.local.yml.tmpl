# {{SLUG}} — LOCAL Docker dev on the PC (topology B).
#
# Runs the whole stack on your machine with native hot-reload (bind-mounted
# source), connecting to the shared MySQL over the LAN. The shared Redis is
# container-only on the divaa host and NOT reachable from the PC, so this stack
# ships its OWN throwaway Redis for cache/session.
#
#   • App page:   http://localhost:{{WEB_PORT}}
#   • Vite HMR:   http://localhost:{{VITE_PORT}} (plain ws — page is http)
#   • MySQL:      192.168.1.21:3306 (shared, reached directly over the LAN)
#   • Redis:      local `redis` container
#
# Bring up:  docker compose -f docker-compose.local.yml up -d --build
# Secrets/overrides come from .env.local (gitignored) via env_file.

services:
  app:
    build:
      context: ./docker/php
    image: {{PREFIX}}-php:{{PHP}}
    # Keep this name — the nginx config resolves the fastcgi upstream by it.
    container_name: {{PREFIX}}-app
    restart: unless-stopped
    working_dir: /var/www/html
    volumes:
      - ./:/var/www/html
    env_file:
      - .env.local

  web:
    image: nginx:1.27-alpine
    container_name: {{PREFIX}}-web-local
    restart: unless-stopped
    depends_on:
      - app
    ports:
      - "{{WEB_PORT}}:80"
    volumes:
      - ./:/var/www/html:ro
      - ./docker/nginx/default.conf:/etc/nginx/conf.d/default.conf:ro

  vite:
    image: node:22-bookworm-slim
    container_name: {{PREFIX}}-vite-local
    restart: unless-stopped
    working_dir: /var/www/html
    command: sh -c "npm install && npm run dev -- --host 0.0.0.0"
    environment:
      VITE_DEV_SERVER_HOST: 0.0.0.0
      VITE_DEV_SERVER_PORT: "{{VITE_PORT}}"
      VITE_HMR_HOST: localhost
      VITE_HMR_CLIENT_PORT: "{{VITE_PORT}}"
      VITE_ALLOWED_HOSTS: localhost
      VITE_CORS_ORIGIN: http://localhost:{{WEB_PORT}}
    ports:
      - "{{VITE_PORT}}:{{VITE_PORT}}"
    volumes:
      - ./:/var/www/html

  redis:
    image: redis:7-alpine
    container_name: {{PREFIX}}-redis-local
    restart: unless-stopped
