# {{SLUG}} — deployment on the shared "divaa-docker" host (192.168.1.21).
#
# Two containers (PHP {{PHP}} FPM + nginx) wired into the host's shared infra:
#   • Traefik reverse proxy -> https://{{APP_DOMAIN}}
#     (routing via the labels below; TLS terminated by Traefik using the
#     *.app.test wildcard cert — no per-project cert work needed).
#   • Shared MySQL 8.0.46   -> reachable as `mysql:3306` on the external `proxy` net.
#   • Shared Redis 7        -> reachable as `redis:6379` on the external `proxy` net
#     (password in .env.divaa). Used for cache + session.
#
# Secrets (DB/Redis credentials) + APP_URL are injected from a HOST-ONLY
# `.env.divaa` file via env_file, so no password is written into this committed
# compose file. Container env overrides the values baked into the app's .env.
#
# This base file is PRODUCTION-style (nginx serves pre-built public/build assets).
# For hot-reload dev, add the dev overlay:
#   docker compose -f docker-compose.divaa.yml -f docker-compose.divaa.dev.yml up -d
#
# Bring up (base only) on the host:
#   cd ~/apps/{{PROJECT_DIR}}
#   docker compose -f docker-compose.divaa.yml up -d --build

services:
  app:
    build:
      context: ./docker/php
    image: {{PREFIX}}-php:{{PHP}}
    container_name: {{PREFIX}}-app
    restart: unless-stopped
    working_dir: /var/www/html
    volumes:
      - ./:/var/www/html
    env_file:
      - .env.divaa
    networks:
      - appnet
      - proxy

  web:
    image: nginx:1.27-alpine
    container_name: {{PREFIX}}-web
    restart: unless-stopped
    depends_on:
      - app
    volumes:
      - ./:/var/www/html:ro
      - ./docker/nginx/default.conf:/etc/nginx/conf.d/default.conf:ro
    networks:
      - appnet
      - proxy
    labels:
      - traefik.enable=true
      # web is multi-homed (appnet + proxy); tell Traefik which network to route on.
      - traefik.docker.network=proxy
      - traefik.http.routers.{{PREFIX}}.rule=Host(`{{APP_DOMAIN}}`)
      - traefik.http.routers.{{PREFIX}}.entrypoints=websecure
      - traefik.http.routers.{{PREFIX}}.tls=true
      - traefik.http.services.{{PREFIX}}.loadbalancer.server.port=80

networks:
  # Private channel for web -> php-fpm (fastcgi). Keeps the fastcgi upstream off
  # the shared proxy network's DNS namespace.
  appnet:
    driver: bridge
  # The host's shared network (Traefik + MySQL + Redis). Created by the divaa
  # infra; we only join it.
  proxy:
    external: true
    name: proxy
