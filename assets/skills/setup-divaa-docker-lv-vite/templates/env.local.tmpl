# LOCAL Docker dev overrides for {{SLUG}} (topology B). NOT committed — gitignored.
# Loaded into the app container via env_file in docker-compose.local.yml, so these
# override the app's baked .env at runtime.
#
# ⚠️ LF line endings only (a trailing CR breaks MySQL/Redis auth).
# ⚠️ DB_PASSWORD: fill in the shared MySQL root password locally (do NOT commit).

APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:{{WEB_PORT}}

# --- Shared MySQL over the LAN ---
DB_CONNECTION=mysql
DB_HOST=192.168.1.21
DB_PORT=3306
DB_DATABASE={{DB}}
DB_USERNAME=root
DB_PASSWORD=

# --- Local throwaway Redis container (cache + session) ---
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_PREFIX={{REDIS_PREFIX}}

CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=database

# --- Shared Mailpit fake SMTP over the LAN (UI: https://mailpit.app.test) ---
# No auth: Mailpit accepts any or no credentials.
MAIL_MAILER=smtp
MAIL_HOST=192.168.1.21
MAIL_PORT=1025
MAIL_ENCRYPTION=null
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@localhost"
MAIL_FROM_NAME="{{SLUG}}"

# --- CORS ---
CORS_ALLOWED_ORIGINS="http://localhost:{{WEB_PORT}}"
