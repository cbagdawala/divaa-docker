# HOST-ONLY overrides for the divaa-docker deployment (NOT committed — gitignored).
# Injected into the `app` container via env_file in docker-compose.divaa.yml.
# These override the values baked into the app's .env at runtime.
#
# ⚠️ LF line endings only. A trailing CR (\r) from a Windows editor gets baked
#    into these values and breaks MySQL/Redis auth. Keep this file Unix-LF.
#
# The base file is production-style; the dev overlay flips APP_ENV=local /
# APP_DEBUG=true on top of these.
#
# ⚠️ Both *_PASSWORD values ship as __INJECT_ON_HOST__ placeholders — the real
#    secrets are injected on the host at deploy time from ~/data/.env, so no
#    credential is ever committed. See docker/README.divaa.md.

APP_ENV=production
APP_DEBUG=false
APP_URL=https://{{APP_DOMAIN}}

# --- Shared MySQL 8.0.46 (reachable as mysql:3306 on the `proxy` network) ---
# Connects as the shared MySQL root user. Database created on the host.
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE={{DB}}
DB_USERNAME=root
DB_PASSWORD=__INJECT_ON_HOST__

# --- Shared Redis 7 (reachable as redis:6379 on the `proxy` network) ---
# Used for cache + session (queue stays on the database connection).
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=__INJECT_ON_HOST__
# Namespace keys so we never collide with other projects on the shared Redis.
REDIS_PREFIX={{REDIS_PREFIX}}

# Kept explicit (not inherited from the committed .env) so this file is
# self-contained: the container's runtime config must never depend on what the
# app's .env happens to say. Change them here, not there.
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=database

# --- Shared Mailpit fake SMTP (reachable as mailpit:1025 on the `proxy` network) ---
# Every message the app "sends" is captured; nothing leaves the network. Read it
# at https://mailpit.app.test (needs a hosts entry — see docker/README.divaa.md).
# No auth: Mailpit accepts any or no credentials.
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_ENCRYPTION=null
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@{{APP_DOMAIN}}"
MAIL_FROM_NAME="{{SLUG}}"

# --- CORS ---
# In dev the browser loads the JS bundle from the webpack-dev-server origin
# ({{HOT_DOMAIN}}), which is a DIFFERENT origin than the app ({{APP_DOMAIN}}) — so
# requests made from that bundle back to the app are cross-origin. Consumed by
# config/cors.php. (The dev server also sends Access-Control-Allow-Origin: * for
# the assets it serves; this is the other direction — the app's own API.)
CORS_ALLOWED_ORIGINS="https://{{APP_DOMAIN}},https://{{HOT_DOMAIN}}"
