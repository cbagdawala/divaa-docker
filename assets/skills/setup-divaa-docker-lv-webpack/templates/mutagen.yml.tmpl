# Mutagen project file — live file sync from this Windows checkout to the shared
# "divaa-docker" host (192.168.1.21), where {{SLUG}} runs as a volume-mounted
# container serving files off the host working copy at
# {{BETA_PATH}} (mapped to /var/www/html in the app container).
# Edits only appear on the host once Mutagen mirrors them (~1.5s).
#
# The dev stack on divaa-docker runs `npm run hot` (webpack-dev-server) + Laravel,
# both watching HOST files — not this PC — so PC edits must be synced up. PHP edits
# are live immediately; .vue/.js edits are live after sync + HMR (~1-2s). In dev
# mode do NOT run `npm run watch` on the PC: the {{PREFIX}}-hot container is the
# builder and serves the bundle from memory.
#
# Lifecycle (run from this directory, which contains mutagen.yml):
#   mutagen project start              # create + start the "{{MUTAGEN_NAME}}" session
#   mutagen project stop               # tear it down
#   mutagen sync list {{MUTAGEN_NAME}} # inspect status
#   mutagen sync list {{MUTAGEN_NAME}} -l  # full config incl. permissions mode
#
# Use `mutagen project start`, NOT `mutagen sync create` with --ignore flags.
# The project file is the single source of truth for ignores AND permissions;
# a CLI-created session silently loses the permissions block below.
#
# WHY THE permissions BLOCK EXISTS (the 0600 gotcha):
# Windows (alpha) has no POSIX modes. With Mutagen's default "Portable"
# permissions mode, every file it writes on the Linux host lands as 0600
# (owner-only). php-fpm runs as www-data, NOT the owner ({{HOST_USER}}), so it
# can't read a 0600 file →
#   include(/var/www/html/...): Failed to open stream: Permission denied
# Forcing 0644 files / 0755 dirs makes synced app code world-readable so
# www-data can serve it. This replaces the old "chmod 644 on the host after
# every edit" workaround.

sync:
  {{MUTAGEN_NAME}}:
    alpha: "."
    beta: "divaa-docker:{{BETA_PATH}}"
    # two-way-resolved => on conflict, THIS machine (alpha) wins. The Vite variant
    # of this skill uses two-way-safe, which flags conflicts instead — the
    # difference is deliberate. A Mix project syncs its COMPILED bundle (see
    # /public below), so the host routinely holds build output that is older than
    # the PC's. Under two-way-safe every stale asset becomes a conflict you must
    # clear by hand; alpha-wins just overwrites it, which is what you meant.
    # The cost: an edit made ON the host to a synced path can be overwritten. Edit
    # on the PC (that is the whole point of topology A) and this never bites.
    mode: "two-way-resolved"
    permissions:
      defaultFileMode: 0644
      defaultDirectoryMode: 0755
    ignore:
      vcs: true          # skip the .git directory
      paths:
        # --- Dependency + build caches (each side manages its own) ---
        - "/vendor"
        - "/node_modules"      # Windows binaries must never reach the Linux host
        - "/package-lock.json" # the hot container's npm rewrites it -> conflict every sync
        - "/bootstrap/cache"
        # --- Host-only secrets (must not be clobbered by the PC copy) ---
        - "/.env.divaa"
        # NOTE: /.env is deliberately NOT ignored — it syncs up, and the container
        # overrides what matters (DB/Redis/APP_URL) from .env.divaa via env_file,
        # so the PC's local values are inert on the host. This keeps ONE APP_KEY
        # across both machines, which is why deploy-divaa.sh can read .env on the
        # host to decide whether key:generate is needed.
        # Ignore it ONLY if the host must keep a different .env from the PC — and
        # if you do, put an .env on the host by hand first, or the app won't boot.
        # (Some older hand-rolled projects on this host ignore it; that predates
        # this skill and is not the pattern to copy.)
        # --- Build / HMR artifacts (host-local) ---
        # NOTE: /public itself is deliberately NOT ignored — unlike the Vite skill,
        # which ignores /public/build. Mix compiles to /public/adminapp, which is
        # gitignored but IS synced, because in PROD mode nginx serves those files
        # off the host and nothing on the host builds them. So: dev mode = the hot
        # container serves from memory and /public/adminapp is unused; prod mode =
        # you `npm run prod` on the PC and Mutagen carries the result up. Ignoring
        # /public would silently break prod deploys.
        - "/public/hot"       # HMR marker — WRITTEN BY THE HOT CONTAINER on the host.
                              # Ignored so the PC neither clobbers it nor imports a
                              # marker pointing at a dev server it can't reach.
        - "/public/storage"   # symlink to storage/app/public
        # --- Laravel runtime state (host-local) ---
        - "/storage/logs"
        - "/storage/framework/cache"
        - "/storage/framework/sessions"
        - "/storage/framework/views"
        # --- Editor / tooling noise ---
        - "/.idea"
        - "/.superpowers"
